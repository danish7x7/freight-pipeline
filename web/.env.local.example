# Local: Supabase stack on :54321, FastAPI backend on :8000.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Sentry error-monitoring DSN (frontend project). Empty => the SDK is DISABLED
# (Sentry.init no-ops) — fail-closed; local dev runs silent. Set the real DSN in
# Vercel at deploy. Error capture only (no tracing/profiling/PII).
NEXT_PUBLIC_SENTRY_DSN=
# Showcase "load sample order" demo panel. "true" => the panel renders on the review
# queue. Must match the backend DEMO_ENABLED (the backend is the authoritative 404 gate).
NEXT_PUBLIC_DEMO_ENABLED=false
