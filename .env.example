# Copy to .env and fill in real values. NEVER commit .env.
# All values below are placeholders.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
# Sentry error-monitoring DSN (backend project). Empty => Sentry stays DISABLED (no
# init, no SDK activity) — fail-closed; local/dev and tests run silent. Set the real
# DSN on Render at deploy. Error capture only (no tracing/profiling); request bodies
# and PII are never sent.
SENTRY_DSN=
# Secret for signing/session use; generate with: openssl rand -hex 32
APP_SECRET=replace-me
# Shared bearer secret guarding the cron endpoints (/poll, /jobs/surcharge).
# One secret for both; generate with: openssl rand -hex 32. Empty => endpoints
# reject all callers (fail-closed). Set the matching GitHub Secret at Phase 8.
CRON_SECRET=replace-me
# Browser origins allowed to call the API (the Next.js review console).
# Comma-separated; empty => no origin allowed (fail-closed). Set the deployed
# console origin (e.g. https://your-app.vercel.app) at Phase 8.
CORS_ALLOW_ORIGINS=http://localhost:3000
# Rate limiting (secondary to auth; fail-open on Redis-down). Per-client per-minute
# cap on each external POST route, and the global LLM-call budget per minute.
RATE_LIMIT_ENABLED=true
PUBLIC_RATE_LIMIT_PER_MINUTE=120
LLM_CALLS_PER_MINUTE=60

# --- Interface selection (swap impls by config, not by code) ---
# llm: mock | hf      gmail: mock | gmail      queue: memory | qstash
LLM_BACKEND=mock
GMAIL_BACKEND=mock
QUEUE_BACKEND=memory

# --- Supabase (Postgres + Auth + Storage) ---
# Local stack: http://127.0.0.1:54321 (used to derive the JWKS URL for JWT verification).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
# Private Storage bucket for PDF attachments (8.3b). Empty => the consumer keeps the
# placeholder reader (body-only path); set to the real bucket name to activate Supabase
# Storage reads. Never hardcoded in code — read from this env var.
SUPABASE_STORAGE_BUCKET=attachments
# Direct Postgres URL for the app / migrations tooling
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freight

# --- Redis (Upstash) — cache, idempotency, rate limiting ---
REDIS_URL=redis://localhost:6379/0

# --- Upstash QStash (queue) ---
QSTASH_TOKEN=replace-me
QSTASH_URL=https://qstash.upstash.io
# Consumer endpoint QStash pushes to (deployed /ingest URL). Real value at Phase 8.
QSTASH_DESTINATION_URL=https://your-app.example/ingest
# Signature verification on /ingest. Real keys from the QStash console at Phase 8;
# the verifier tries CURRENT then NEXT so a key rotation doesn't reject deliveries.
QSTASH_CURRENT_SIGNING_KEY=replace-me
QSTASH_NEXT_SIGNING_KEY=replace-me
# Expected signed `sub` claim = the public /ingest URL. Configurable, not hard-coded;
# real public URL wired at Phase 8. Empty => sub is not matched (claim still required).
QSTASH_EXPECTED_URL=https://your-app.example/ingest

# --- Hugging Face Inference Providers (LLM, OpenAI-compatible chat-completions) ---
# Token: a fine-grained HF token with "Make calls to Inference Providers" permission.
HF_TOKEN=replace-me
# PINNED at Phase 8.2 (see DECISIONS 2026-06-15). A bare org/model auto-routes to the
# fastest provider (:fastest default); append :cheapest or :<provider> to pin determinism
# for the Phase 9 eval. json_object response_format is honored server-side on this model.
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct
HF_BASE_URL=https://router.huggingface.co

# --- Gmail OAuth (least-privilege: readonly + send) ---
GMAIL_CLIENT_ID=replace-me
GMAIL_CLIENT_SECRET=replace-me
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
# Single-inbox refresh token (the one runtime secret; no token table). Real at Phase 8.
GMAIL_REFRESH_TOKEN=replace-me
