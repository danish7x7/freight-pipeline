# Copy to .env and fill in real values. NEVER commit .env.
# All values below are placeholders.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
# Secret for signing/session use; generate with: openssl rand -hex 32
APP_SECRET=replace-me

# --- Interface selection (swap impls by config, not by code) ---
# llm: mock | hf      gmail: mock | gmail      queue: memory | qstash
LLM_BACKEND=mock
GMAIL_BACKEND=mock
QUEUE_BACKEND=memory

# --- Supabase (Postgres + Auth + Storage) ---
# Local stack: http://127.0.0.1:54321 (used to derive the JWKS URL for JWT verification).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
# Direct Postgres URL for the app / migrations tooling
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freight

# --- Redis (Upstash) — cache, idempotency, rate limiting ---
REDIS_URL=redis://localhost:6379/0

# --- Upstash QStash (queue) ---
QSTASH_TOKEN=replace-me
QSTASH_URL=https://qstash.upstash.io
# Consumer endpoint QStash pushes to (deployed /ingest URL). Real value at Phase 8.
QSTASH_DESTINATION_URL=https://your-app.example/ingest

# --- Hugging Face serverless inference (LLM, OpenAI-compatible chat-completions) ---
HF_TOKEN=replace-me
HF_MODEL=replace-me
HF_BASE_URL=https://router.huggingface.co

# --- Gmail OAuth (least-privilege: readonly + send) ---
GMAIL_CLIENT_ID=replace-me
GMAIL_CLIENT_SECRET=replace-me
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback
# Single-inbox refresh token (the one runtime secret; no token table). Real at Phase 8.
GMAIL_REFRESH_TOKEN=replace-me
